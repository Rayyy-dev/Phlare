# ─────────────────────────────────────────────────────────────────────────────
# Phlare — environment configuration
# Copy this file to `.env` and adjust. NEVER commit a real `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# --- Core ---------------------------------------------------------------------
# Public base URL of the deployment. Tracking links (pixel, click, landing pages)
# are built from this, so it MUST be reachable by recipients' mail clients.
APP_BASE_URL=http://localhost:3000
NODE_ENV=development

# --- Database (PostgreSQL) ----------------------------------------------------
POSTGRES_USER=phlare
POSTGRES_PASSWORD=phlare_dev_password
POSTGRES_DB=phlare
# Inside docker-compose the host is the service name `postgres`; locally use localhost.
DATABASE_URL=postgresql://phlare:phlare_dev_password@localhost:5432/phlare?schema=public

# --- Redis (BullMQ queue/worker) ----------------------------------------------
# Inside docker-compose the host is `redis`; locally use localhost.
REDIS_URL=redis://localhost:6379

# --- Security secrets ---------------------------------------------------------
# Used to sign/verify session-related material. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_generate_a_32_byte_hex_secret
# AES-256-GCM key (exactly 32 bytes, hex = 64 chars) used to encrypt SMTP
# credentials at rest. Generate with the same command as above.
APP_ENCRYPTION_KEY=change_me_64_hex_chars_for_a_32_byte_aes_key

# --- Local mail-catcher (Mailpit) ---------------------------------------------
# Dev SMTP sink so simulated campaigns can be demonstrated without a live server.
# Web UI: http://localhost:8025
MAILPIT_SMTP_HOST=localhost
MAILPIT_SMTP_PORT=1025
